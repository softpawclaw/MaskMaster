--- !u!114 &1824929161
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1824929156}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 438865801ec946a48c9fedb3e37f3011, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::Systems.DialogueSystem
  controllerUI: {fileID: 378273943}
  config:
  - Id: DI_F_NoText
    Text: 
    Delay: 0
  - Id: DI_F_Night
    Text: NIGHT
    Delay: 0
  - Id: DI_EndDayPlug
    Text: "\u0421\u043B\u0430\u0432\u043D\u0430\u044F \u0444\u0435\u0439\u043A\u043E\u0432\u0430\u044F
      \u0440\u0430\u0431\u043E\u0442\u0430. \u041E\u0442\u043F\u0440\u0430\u0432\u043B\u044F\u0439\u0441\u044F
      \u0432 \u043A\u043E\u043C\u043D\u0430\u0442\u0443. \u0421\u043B\u0443\u0436\u043A\u0438
      \u0432\u0441\u0435 \u043F\u0440\u0438\u0431\u0435\u0440\u0443\u0442, \u043D\u0435\u0433\u043E\u0436\u0435
      \u043D\u0430\u043F\u0440\u044F\u0433\u0430\u0442\u044C \u044D\u0442\u0438\u043C
      \u0442\u0430\u043A\u043E\u0433\u043E \u0412\u0415\u041B\u0418\u041A\u041E\u0413\u041E
      \u043C\u0430\u0441\u0442\u0435\u0440\u0430. \u0410\u0445-\u0445\u0430-\u0445\u0430-\u0445\u0430-\u0445\u0430"
    Delay: 0
  - Id: DI_10
    Text: "\u0412\u0435\u0447\u0435\u0440 \u0440\u0430\u0437\u0433\u0430\u0440\u0430\u0435\u0442\u0441\u044F,
      \u043A\u043B\u0438\u0435\u043D\u0442\u044B \u043D\u0430 \u043F\u043E\u0434\u0445\u043E\u0434\u0435!
      \u041F\u0440\u043E\u0441\u044B\u043F\u0430\u0439\u0442\u0435\u0441\u044C, \u043A\u0440\u044B\u0441\u044B!
      \u042D\u0439, \u0442\u044B, \u043D\u043E\u0432\u0435\u043D\u044C\u043A\u0438\u0439,
      \u0437\u0430\u0434\u0435\u0440\u0436\u0438\u0441\u044C \u0438 \u043F\u043E\u0441\u043B\u0443\u0448\u0430\u0439..."
    Delay: 0
  - Id: DI_11
    Text: "\u042D\u0442\u043E \u043D\u0435\u043C\u043D\u043E\u0433\u043E \u0448\u043E\u043A\u0438\u0440\u0443\u0435\u0442,
      \u043D\u043E \u043D\u0435\u0432\u044B\u043F\u043E\u043B\u043D\u0435\u043D\u0438\u0435
      \u0440\u0430\u0431\u043E\u0442\u044B \u0438 \u0441\u043C\u0435\u0440\u0442\u044C
      \u0432\u043C\u0435\u0441\u0442\u043E \u0448\u043E\u043A\u0430 \u0441\u0442\u0430\u0432\u0438\u0442
      \u0442\u043E\u0447\u043A\u0443. \u0422\u0430\u043A \u0447\u0442\u043E \u0432\u044B\u0431\u0438\u0440\u0430\u0439\u0441\u044F
      \u0438\u0437 \u043A\u0430\u043C\u0435\u0440\u044B \u0438 \u0436\u0434\u0438
      \u043A\u043E\u0433\u0434\u0430 \u0442\u0435\u0431\u044F \u043F\u043E\u0437\u043E\u0432\u0435\u0442
      \u043A\u043E\u043B\u043E\u043A\u043E\u043B\u044C\u0447\u0438\u043A. \u0421\u0430\u043C
      \u0432\u0441\u0435 \u043F\u043E\u0439\u043C\u0435\u0448\u044C."
    Delay: 0
  - Id: DI_12
    Text: "\u0412\u0430\u0448\u0430 \u043B\u0430\u0432\u043A\u0430 \u0432\u0441\u0435\u0433\u0434\u0430
      \u0441\u043B\u0430\u0432\u0438\u043B\u0430\u0441\u044C \u0441\u043A\u043E\u0440\u043E\u0441\u0442\u044C\u044E
      \u0438 \u043A\u0430\u0447\u0435\u0441\u0442\u0432\u043E\u043C. \u041D\u0435
      \u043F\u043E\u0434\u0432\u0435\u0434\u0438, \u0437\u0430\u0441\u0442\u0440\u0435\u043B\u044C\u0449\u0438\u043A\u0438
      \u043D\u0435 \u0434\u0440\u0435\u043C\u043B\u044E\u0442."
    Delay: 0
  - Id: DI_13
    Text: "\u041D\u0430\u0434\u0435\u044E\u0441\u044C, \u043C\u043E\u0439 \u0437\u0430\u043A\u0430\u0437
      \u0443\u0436\u0435 \u0438\u0441\u043F\u043E\u043B\u043D\u0435\u043D. \u041D\u0435
      \u0437\u0430\u0441\u0442\u0430\u0432\u043B\u044F\u0439 \u043C\u0435\u043D\u044F
      \u0436\u0434\u0430\u0442\u044C. \u0421\u043A\u043E\u0440\u043E \u0440\u0430\u0441\u0441\u0432\u0435\u0442
      - \u0432\u0440\u0435\u043C\u0435\u043D\u0438 \u043D\u0435\u0442."
    Delay: 0
  - Id: DI_14
    Text: "\u0421\u043B\u0430\u0432\u043D\u0430\u044F \u0440\u0430\u0431\u043E\u0442\u0430,
      \u0442\u0435\u043F\u0435\u0440\u044C \u044F \u0441\u043C\u043E\u0433\u0443
      \u0441\u043A\u0440\u044B\u0432\u0430\u0442\u044C\u0441\u044F \u043E\u0442 \u044D\u0442\u0438\u0445
      \u043E\u043B\u0443\u0445\u043E\u0432 \u043F\u0440\u044F\u043C\u043E \u0443
      \u043D\u0438\u0445 \u043F\u043E\u0434 \u043D\u043E\u0441\u043E\u043C."
    Delay: 0
  - Id: DI_15
    Text: "\u0422\u044B \u0443\u0432\u0435\u0440\u0435\u043D, \u0447\u0442\u043E
      \u044D\u0442\u043E \u0442\u043E, \u0447\u0442\u043E \u044F \u043F\u0440\u043E\u0441\u0438\u043B,
      \u0442\u0435\u0431\u0435, \u043A\u043E\u043D\u0435\u0447\u043D\u043E \u0432\u0438\u0434\u043D\u0435\u0435,
      \u043D\u043E \u043E\u0442 \u044D\u0442\u043E\u0433\u043E \u0437\u0430\u0432\u0438\u0441\u0438\u0442
      \u043C\u043E\u044F \u0436\u0438\u0437\u043D\u044C... \u041B\u0430\u0434\u043D\u043E,
      \u0434\u0430\u0432\u0430\u0439 \u0441\u044E\u0434\u0430."
    Delay: 0
  - Id: DI_20
    Text: "\u0412\u043E\u0442 \u0432\u0438\u0434\u0438\u0448\u044C, \u0440\u0443\u0442\u0438\u043D\u0430
      \u044D\u0442\u043E \u043D\u0435 \u0442\u0430\u043A \u0443\u0436 \u0438 \u043F\u043B\u043E\u0445\u043E,
      \u043C\u043E\u044F \u043C\u0430\u043B\u0435\u043D\u044C\u043A\u0430\u044F \u043A\u0440\u044B\u0441\u043A\u0430.
      \u0428\u0435\u0432\u0435\u043B\u0438 \u043B\u0430\u043F\u043A\u0430\u043C\u0438,
      \u043F\u043E\u043A\u0430 \u0435\u0441\u0442\u044C \u0447\u0435\u043C \u0448\u0435\u0432\u0435\u043B\u0438\u0442\u044C."
    Delay: 0
